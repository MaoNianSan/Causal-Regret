# Project-local runtime/cache
.runtime/
tmp/
temp/
cache/
__pycache__/
src/__pycache__/
.ipynb_checkpoints/
fixture_config.yaml

# Raw or downloaded data
data/raw/
data/external/
downloads/
datasets/
inputs/pcb_dataset_final.tsv
inputs/criteo_attribution_dataset.tsv.gz
inputs/**/*.tsv
inputs/**/*.tsv.gz

# Heavy intermediate outputs
outputs/**/intermediate/
outputs/**/cache/
outputs/**/raw_large/
outputs/**/processed/
outputs/**/raw/
outputs/**/*.pkl
outputs/**/*.joblib
outputs/**/*.npy
outputs/**/*.npz
outputs/**/*.parquet

# Keep lightweight GitHub-facing outputs
!outputs/**/summary*.csv
!outputs/**/summaries/**
!outputs/**/tables/**
!outputs/**/figures/**
!outputs/**/checks/**
!outputs/**/metadata/**
!output_manifest.md
!docs/**
!ipy/**
!runlogs/*.txt
!runlogs/*.md
!runlogs/*.log
